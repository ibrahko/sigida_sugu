# ── Variables d'environnement Railway ─────────────────────────────────────────
# Copier ce fichier, le remplir et configurer chaque variable dans le dashboard
# Railway → service → Variables.
#
# Les variables marquées [AUTO] sont fournies automatiquement par Railway
# quand tu ajoutes le plugin correspondant (PostgreSQL, Redis).
# ─────────────────────────────────────────────────────────────────────────────

# Django
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=                          # Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=0
ALLOWED_HOSTS=                       # Domaine Railway ex: web-production-xxxx.up.railway.app,ton-domaine.com
FRONTEND_URL=                        # URL du service frontend ex: https://frontend-production-xxxx.up.railway.app

# Base de données PostgreSQL [AUTO quand plugin Railway ajouté]
DATABASE_URL=                        # Fourni par Railway — format: postgresql://user:password@host:port/db
# Ou en variables séparées si tu n'utilises pas DATABASE_URL :
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

# Redis [AUTO quand plugin Railway ajouté]
REDIS_URL=                           # Fourni par Railway — format: redis://default:password@host:port
CELERY_BROKER_URL=                   # Même valeur que REDIS_URL (ou redis://…/1)
CELERY_RESULT_BACKEND=               # Même valeur que REDIS_URL (ou redis://…/2)

# CORS / CSRF
CORS_ALLOWED_ORIGINS=                # ex: https://frontend-production-xxxx.up.railway.app
CSRF_TRUSTED_ORIGINS=                # ex: https://web-production-xxxx.up.railway.app

# Paiement InTouch Mobile Money
INTTOUCH_BASE_URL=https://api.intouchpayments.com
INTTOUCH_USERNAME=
INTTOUCH_PARTNER_PASSWORD=
INTTOUCH_ACCOUNT_NO=
INTTOUCH_API_KEY=
INTTOUCH_API_SECRET=
INTTOUCH_CALLBACK_URL=               # ex: https://web-production-xxxx.up.railway.app/api/v1/payments/webhook/intouch/
INTTOUCH_WEBHOOK_SECRET=
INTTOUCH_SANDBOX=false               # Passer à true pour les tests en prod

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net         # ou smtp.mailgun.org, smtp.resend.com…
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@sigidasugu.com

# Sentry (monitoring d'erreurs)
SENTRY_DSN=                          # Depuis https://sentry.io — optionnel mais recommandé

# ── Services Railway à créer ──────────────────────────────────────────────────
#
# 1. web        → Dockerfile: Dockerfile (racine)
#                 Start: gunicorn config.wsgi:application --bind 0.0.0.0:$PORT --workers 2 --threads 2
#
# 2. worker     → Dockerfile: Dockerfile (racine)
#                 Start: celery -A config.celery worker --loglevel=info --concurrency=2
#                 (pas de PORT exposé)
#
# 3. beat       → Dockerfile: Dockerfile (racine)
#                 Start: celery -A config.celery beat --loglevel=info
#                 (pas de PORT exposé)
#
# 4. frontend   → Dockerfile: frontend/sigidasugu/Dockerfile
#                 Build arg: VITE_API_URL=https://web-production-xxxx.up.railway.app/api/v1
#                 Port: 80
#
# 5. PostgreSQL → Ajouter le plugin Railway PostgreSQL
# 6. Redis      → Ajouter le plugin Railway Redis
# ─────────────────────────────────────────────────────────────────────────────
